{
  "name": "celar-waitlist-site",
  "private": true,
  "version": "1.0.0",
  "description": "Static waitlist site",
  "scripts": {
    "dev": "npx serve .",
    "fetch:ignite": "node ./scripts/fetch-ignite-leaderboard.mjs",
    "fetch:ignite:full": "node ./scripts/fetch-ignite-leaderboard-full.mjs",
    "start": "npx serve .",
    "mojo": "node ./scripts/runner.mjs",
    "pm2:start": "pm2 start ./scripts/runner.mjs --name celar-runner --interpreter node",
    "pm2:restart": "pm2 restart celar-runner",
    "pm2:stop": "pm2 stop celar-runner",
    "pm2:delete": "pm2 delete celar-runner",
    "pm2:logs": "pm2 logs celar-runner"
  },
  "dependencies": {
    "playwright": "^1.59.1",
    "pm2": "^5.4.3"
  }
}
